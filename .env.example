# GitHub personal access token (fine-grained, read-only, public repos).
# Required for live contribution heatmap + repo/contribution stats.
# Without it, the portfolio falls back to hardcoded values.
GITHUB_TOKEN=

# Vercel CLI token (optional — only needed for `just deploy` / `just deploy-prod`).
VERCEL_TOKEN=

# Production site URL — used for canonical URLs, sitemap, and JSON-LD.
# Set this to your real domain in Vercel env vars.
NEXT_PUBLIC_SITE_URL=https://vinicius-portfolio-source.vercel.app

# Resend API key (optional — enables the contact form).
# Without it, the form returns a 503 and the user is directed to email directly.
# Sign up at https://resend.com (free tier: 100 emails/day).
RESEND_API_KEY=

# defaults to the onboarding@resend.dev sandbox sender — set to a verified domain address in production
RESEND_FROM_EMAIL=

# Cloudflare Turnstile — server-side proof-of-work challenge for the contact
# form. Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# (Managed mode). Site key is public (ships in the client bundle); secret key
# is server-only and must never be logged or exposed to the client.
# Without these set in production, the contact route fails closed (503) —
# it never silently skips the challenge. Local dev and automated tests use
# Cloudflare's official always-pass test keys instead of real ones:
#   site key   1x00000000000000000000AA
#   secret key 1x0000000000000000000000000000000AA
# (https://developers.cloudflare.com/turnstile/troubleshooting/testing/)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Hostname siteverify responses must match — set to your real domain.
TURNSTILE_EXPECTED_HOSTNAME=

# Distributed rate limiting for the contact route (Upstash Redis), shared
# across serverless instances — an in-memory limiter alone resets per cold
# start and isn't shared. Provision via the Vercel Marketplace (Storage tab
# → Upstash) or upstash.com directly. The Vercel Marketplace integration
# names these KV_REST_API_* (legacy naming carried over from Vercel KV); set
# them to whatever your provisioning path actually calls them.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Pepper used to HMAC client IPs before using them as rate-limit keys — never
# store raw IPs in the Redis store. Generate with: openssl rand -hex 32
RATE_LIMIT_HASH_SECRET=

# DeepL API key — only used by `npm run i18n:translate` (a local/CI-only
# CLI, see docs/adr/0001-deepl-translation-provider.md). Never read by the
# app itself, so the site builds and runs fine without it. Sign up for a
# free key (500k chars/month) at https://www.deepl.com/pro-api. Free-tier
# keys end in ":fx" but that's never relied on — set DEEPL_API_ENDPOINT
# explicitly instead.
DEEPL_API_KEY=

# "free" or "pro" — must match your DeepL account's tier explicitly.
# Defaults to "free" if unset.
DEEPL_API_ENDPOINT=free

# Global kill switch for the limited #48 Three.js rollout. Only the selected
# project dossiers in src/lib/feature-flags.ts can render WebGL; the initial
# route is personal-platform-infra. Hero, home, cards and mobile remain 2.5D.
# Set to exactly "true" to activate the eligible dossier, or leave unset/
# "false" for an immediate rollback. See docs/topology-3d-spike.md.
NEXT_PUBLIC_ENABLE_3D_TOPOLOGY=
