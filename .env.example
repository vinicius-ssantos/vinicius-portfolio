# GitHub personal access token (fine-grained, read-only, public repos).
# Required for live contribution heatmap + repo/contribution stats.
# Without it, the portfolio falls back to hardcoded values.
GITHUB_TOKEN=

# Vercel CLI token (optional — only needed for `just deploy` / `just deploy-prod`).
VERCEL_TOKEN=

# Production site URL — used for canonical URLs, sitemap, and JSON-LD.
# Set this to your real domain in Vercel env vars.
NEXT_PUBLIC_SITE_URL=https://vinicius-portfolio-source.vercel.app
