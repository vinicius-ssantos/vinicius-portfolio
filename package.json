{
  "name": "vinicius-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "i18n:quality": "node scripts/i18n-quality.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "i18n:translate": "node scripts/i18n-translate.mjs",
    "i18n:status": "node scripts/i18n-status.mjs",
    "i18n:review": "node scripts/i18n-review.mjs",
    "preflight": "npm run lint && npm run typecheck && npm run format:check && npm run test && npm run i18n:check && npm run build",
    "clean": "node scripts/clean.mjs build",
    "clean:cache": "node scripts/clean.mjs cache",
    "clean:all": "node scripts/clean.mjs all && npm install",
    "check-env": "node scripts/check-env.mjs",
    "env:sync": "node scripts/sync-env-example.mjs",
    "doctor": "node scripts/doctor.mjs",
    "deploy": "npm run preflight && npx vercel",
    "deploy:prod": "npm run preflight && npx vercel --prod"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@react-three/fiber": "^9.6.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "next": "^16.2.11",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.18.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.11",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.6.2"
}
